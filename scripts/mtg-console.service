[Unit]
Description=MTG Console
After=network.target

[Service]
Type=simple
User=dev
Group=dev
WorkingDirectory=/home/dev/mtg-console
ExecStart=/home/dev/mtg-console/.venv/bin/python run.py
Restart=on-failure
RestartSec=5
Environment=PYTHONUNBUFFERED=1
StandardOutput=journal
StandardError=journal
# Uncomment to run with mock hardware during testing:
# Environment=MOCK_PRINTER=true
# Environment=MOCK_DISPLAY=true

[Install]
WantedBy=multi-user.target
